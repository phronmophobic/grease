#!/bin/bash
set -x
set -e

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
cd "$DIR"

cd ..



pushd third_party

if ! [ -d graalvm-jdk-21.0.3+7.1 ]; then
    curl -O -sL "https://download.oracle.com/graalvm/21/archive/graalvm-jdk-21.0.3_macos-aarch64_bin.tar.gz"
    tar xzf graalvm-jdk-21.0.3_macos-aarch64_bin.tar.gz
    rm graalvm-jdk-21.0.3_macos-aarch64_bin.tar.gz
fi

if ! [ -d libffi-3.4.8 ]; then
    curl -O -sL "https://github.com/libffi/libffi/releases/download/v3.4.8/libffi-3.4.8.tar.gz"
    tar xzf libffi-3.4.8.tar.gz
    rm libffi-3.4.8.tar.gz

fi

popd
